@model IList<Product>
@{
    ViewData["Title"] = "Sản phẩm";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h3 mb-0">Sản phẩm</h1>
    <a class="btn btn-primary" asp-action="Create">Thêm sản phẩm</a>
</div>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-6 col-lg-4">
        <div class="input-group">
            <input type="search" name="q" class="form-control" placeholder="Tìm theo tên, mô tả..." value="@ViewBag.SearchQuery" />
            <button class="btn btn-outline-secondary" type="submit">Tìm</button>
        </div>
    </div>
</form>
<div class="table-responsive card border-0 shadow-sm">
<table class="table table-hover align-middle mb-0">
    <thead class="table-light">
        <tr><th>Ảnh</th><th>Tên</th><th>Danh mục</th><th>Giá</th><th>Tồn</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            var img = string.IsNullOrEmpty(p.ImageUrl) ? "/images/placeholder-product.svg" : p.ImageUrl;
            <tr>
                <td style="width:72px"><img src="@img" alt="" class="img-thumbnail" style="height:48px;width:48px;object-fit:cover" /></td>
                <td>@p.Name</td>
                <td>@p.Category?.Name</td>
                <td>@p.Price.ToString("N0")</td>
                <td>@p.Stock</td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@p.Id">Sửa</a>
                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Xóa sản phẩm?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@p.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>
