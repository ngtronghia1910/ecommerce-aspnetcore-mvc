@model IList<Category>
@{
    ViewData["Title"] = "Danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Danh mục</h1>
    <a class="btn btn-primary" asp-action="Create">Thêm danh mục</a>
</div>
<table class="table table-bordered bg-white">
    <thead><tr><th>Tên</th><th>Mô tả</th><th></th></tr></thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td>@c.Description</td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@c.Id">Sửa</a>
                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Xóa danh mục này?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@c.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
