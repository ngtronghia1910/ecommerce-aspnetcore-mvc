@model IList<ECommerceWeb.Models.Coupon>
@using ECommerceWeb.Models
@{
    ViewData["Title"] = "Mã giảm giá";
    string TypeVi(CouponDiscountType t) => t == CouponDiscountType.Percent ? "%" : "VNĐ cố định";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Mã giảm giá</h1>
    <a class="btn btn-primary" asp-action="Create">Thêm mã</a>
</div>
<table class="table table-bordered bg-white table-sm align-middle">
    <thead>
        <tr>
            <th>Mã</th>
            <th>Loại</th>
            <th>Giá trị</th>
            <th>Đơn tối thiểu</th>
            <th>Lượt dùng</th>
            <th>Hiệu lực (UTC)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr class="@(c.IsActive ? "" : "table-secondary")">
                <td class="fw-semibold">@c.Code</td>
                <td>@TypeVi(c.DiscountType)</td>
                <td>@(c.DiscountType == CouponDiscountType.Percent ? $"{c.Value}%" : $"{c.Value:N0} đ")</td>
                <td>@(c.MinOrderValue.HasValue ? $"{c.MinOrderValue:N0} đ" : "—")</td>
                <td>@c.UsedCount / @(c.UsageLimit?.ToString() ?? "∞")</td>
                <td class="small">@c.StartDateUtc.ToString("dd/MM HH:mm") → @c.EndDateUtc.ToString("dd/MM HH:mm")</td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@c.Id">Sửa</a>
                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Xóa mã này?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@c.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
