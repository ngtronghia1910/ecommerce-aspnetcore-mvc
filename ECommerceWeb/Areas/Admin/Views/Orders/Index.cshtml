@model IList<Order>
@{
    ViewData["Title"] = "Đơn hàng";
    string StatusVi(OrderStatus s) => s switch
    {
        OrderStatus.Pending => "Chờ xử lý",
        OrderStatus.Processing => "Đang xử lý",
        OrderStatus.Shipped => "Đang giao",
        OrderStatus.Delivered => "Hoàn thành",
        OrderStatus.Cancelled => "Đã hủy",
        OrderStatus.AwaitingPayment => "Chờ thanh toán online",
        _ => s.ToString()
    };
}

<h1 class="h3 mb-3">Đơn hàng</h1>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-6 col-lg-4">
        <div class="input-group">
            <input type="search" name="q" class="form-control" placeholder="Email, mã đơn, SĐT..." value="@ViewBag.SearchQuery" />
            <button class="btn btn-outline-secondary" type="submit">Lọc</button>
        </div>
    </div>
</form>
<div class="table-responsive card border-0 shadow-sm">
<table class="table table-hover align-middle mb-0">
    <thead class="table-light">
        <tr><th>Mã</th><th>Khách</th><th>Ngày</th><th>Tổng</th><th>TT</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>#@o.Id</td>
                <td>@(o.User?.Email ?? o.UserId)</td>
                <td>@o.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                <td>@o.TotalAmount.ToString("N0") đ</td>
                <td>@StatusVi(o.Status)</td>
                <td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@o.Id">Chi tiết</a></td>
            </tr>
        }
    </tbody>
</table>
</div>
