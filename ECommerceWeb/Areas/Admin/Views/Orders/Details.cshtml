@model Order
@{
    ViewData["Title"] = "Đơn #" + Model.Id;
    string StatusVi(OrderStatus s) => s switch
    {
        OrderStatus.Pending => "Chờ xử lý",
        OrderStatus.Processing => "Đang xử lý",
        OrderStatus.Shipped => "Đang giao",
        OrderStatus.Delivered => "Hoàn thành",
        OrderStatus.Cancelled => "Đã hủy",
        OrderStatus.AwaitingPayment => "Chờ thanh toán online",
        _ => s.ToString()
    };
    string PayVi(PaymentMethod m) => m switch
    {
        PaymentMethod.Cod => "COD",
        PaymentMethod.VNPay => "VNPay",
        PaymentMethod.Momo => "MoMo",
        _ => m.ToString()
    };
    string PayStatusVi(PaymentStatus p) => p switch
    {
        PaymentStatus.None => "—",
        PaymentStatus.Pending => "Chờ thanh toán",
        PaymentStatus.Paid => "Đã thanh toán",
        PaymentStatus.Failed => "Thanh toán lỗi",
        _ => p.ToString()
    };
}

<h1 class="h4">Đơn #@Model.Id</h1>
<p>Khách: <strong>@(Model.User?.Email)</strong> — @Model.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
<p>@Model.ShippingName — @Model.ShippingPhone<br />@Model.ShippingAddress</p>

<table class="table">
    <thead><tr><th>Sản phẩm</th><th>Đơn giá</th><th>SL</th><th>Thành tiền</th></tr></thead>
    <tbody>
        @foreach (var d in Model.OrderDetails)
        {
            <tr>
                <td>@d.ProductName</td>
                <td>@d.UnitPrice.ToString("N0") đ</td>
                <td>@d.Quantity</td>
                <td>@((d.UnitPrice * d.Quantity).ToString("N0")) đ</td>
            </tr>
        }
    </tbody>
</table>
<p class="mb-1"><strong>Tạm tính:</strong> @Model.SubtotalAmount.ToString("N0") đ
    @if (Model.CouponDiscountAmount > 0)
    {
        <text> — <strong>Giảm (@Model.AppliedCouponCode):</strong> @Model.CouponDiscountAmount.ToString("N0") đ</text>
    }
</p>
<p class="fw-bold">Thành tiền: @Model.TotalAmount.ToString("N0") đ — Trạng thái: @StatusVi(Model.Status)</p>
<p><strong>Thanh toán:</strong> @PayVi(Model.PaymentMethod) / @PayStatusVi(Model.PaymentStatus) @if (!string.IsNullOrEmpty(Model.GatewayTxnRef)) { <text>— <code>@Model.GatewayTxnRef</code></text> }</p>

<form asp-action="UpdateStatus" method="post" class="row g-2 align-items-end">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <div class="col-auto">
        <label class="form-label">Cập nhật trạng thái</label>
        <select name="status" class="form-select">
            @foreach (OrderStatus s in Enum.GetValues(typeof(OrderStatus)))
            {
                if (Model.Status == s)
                {
                    <option value="@((int)s)" selected>@StatusVi(s)</option>
                }
                else
                {
                    <option value="@((int)s)">@StatusVi(s)</option>
                }
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Lưu</button>
    </div>
</form>
<p class="mt-3"><a asp-action="Index">&larr; Danh sách</a></p>
