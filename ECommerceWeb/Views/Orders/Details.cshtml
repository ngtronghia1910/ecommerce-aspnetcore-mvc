@model Order
@{
    ViewData["Title"] = "Chi tiết đơn #" + Model.Id;
    string StatusVi(OrderStatus s) => s switch
    {
        OrderStatus.Pending => "Chờ xử lý",
        OrderStatus.Processing => "Đang xử lý",
        OrderStatus.Shipped => "Đang giao",
        OrderStatus.Delivered => "Hoàn thành",
        OrderStatus.Cancelled => "Đã hủy",
        OrderStatus.AwaitingPayment => "Chờ thanh toán online",
        _ => s.ToString()
    };
    string PayVi(PaymentMethod m) => m switch
    {
        PaymentMethod.Cod => "Thanh toán khi nhận hàng (COD)",
        PaymentMethod.VNPay => "VNPay",
        PaymentMethod.Momo => "Ví MoMo",
        _ => m.ToString()
    };
    string PayStatusVi(PaymentStatus p) => p switch
    {
        PaymentStatus.None => "Không qua cổng (COD)",
        PaymentStatus.Pending => "Đang chờ thanh toán",
        PaymentStatus.Paid => "Đã thanh toán",
        PaymentStatus.Failed => "Thanh toán thất bại",
        _ => p.ToString()
    };
}

<h1 class="h3">Đơn hàng #@Model.Id</h1>
<p class="text-muted">@Model.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm") — @StatusVi(Model.Status)</p>
<p><strong>Thanh toán:</strong> @PayVi(Model.PaymentMethod) — @PayStatusVi(Model.PaymentStatus)</p>
@if (!string.IsNullOrEmpty(Model.GatewayTxnRef))
{
    <p class="small text-muted">Mã giao dịch cổng: <code>@Model.GatewayTxnRef</code></p>
}

<p><strong>Người nhận:</strong> @Model.ShippingName<br />
<strong>Điện thoại:</strong> @Model.ShippingPhone<br />
<strong>Địa chỉ:</strong> @Model.ShippingAddress</p>

<table class="table">
    <thead>
        <tr><th>Sản phẩm</th><th>Đơn giá</th><th>SL</th><th>Thành tiền</th></tr>
    </thead>
    <tbody>
        @foreach (var d in Model.OrderDetails)
        {
            <tr>
                <td>@d.ProductName</td>
                <td>@d.UnitPrice.ToString("N0") đ</td>
                <td>@d.Quantity</td>
                <td>@((d.UnitPrice * d.Quantity).ToString("N0")) đ</td>
            </tr>
        }
    </tbody>
</table>
<div class="card border-0 bg-light mb-3" style="max-width: 24rem;">
    <div class="card-body py-3">
        <div class="d-flex justify-content-between small mb-1">
            <span>Tạm tính</span>
            <span>@Model.SubtotalAmount.ToString("N0") đ</span>
        </div>
        @if (Model.CouponDiscountAmount > 0)
        {
            <div class="d-flex justify-content-between small text-success mb-1">
                <span>Giảm (@Model.AppliedCouponCode)</span>
                <span>−@Model.CouponDiscountAmount.ToString("N0") đ</span>
            </div>
        }
        <div class="d-flex justify-content-between fw-bold border-top pt-2">
            <span>Thành tiền</span>
            <span class="text-brand">@Model.TotalAmount.ToString("N0") đ</span>
        </div>
    </div>
</div>
<a asp-action="MyOrders">&larr; Danh sách đơn</a>
