@model IList<ECommerceWeb.Models.Category>
@{
    ViewData["Title"] = "Danh mục";
}

<h1 class="h3 mb-4">Danh mục sản phẩm</h1>
@if (!Model.Any())
{
    <div class="empty-state card border-0 shadow-sm">
        <div class="empty-state-icon" aria-hidden="true">📂</div>
        <p class="mb-0">Chưa có danh mục.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var c in Model)
        {
            <div class="col-sm-6 col-md-4 col-lg-3">
                <a class="text-decoration-none" asp-controller="Products" asp-action="Index" asp-route-categoryId="@c.Id">
                    <div class="card h-100 border-0 shadow-sm product-card p-4">
                        <h2 class="h5 text-dark">@c.Name</h2>
                        @if (!string.IsNullOrEmpty(c.Description))
                        {
                            <p class="small text-secondary mb-0">@c.Description</p>
                        }
                        <span class="mt-3 text-brand fw-semibold small">Xem sản phẩm →</span>
                    </div>
                </a>
            </div>
        }
    </div>
}
