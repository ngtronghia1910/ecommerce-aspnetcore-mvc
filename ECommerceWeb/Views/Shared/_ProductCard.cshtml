@model Product
@using ECommerceWeb.Models
@{
    var img = string.IsNullOrEmpty(Model.ImageUrl) ? "/images/placeholder-product.svg" : Model.ImageUrl;
    var auth = User.Identity?.IsAuthenticated == true;
    var hasDisc = ProductPricing.HasDiscount(Model);
    var effective = ProductPricing.GetEffectiveUnitPrice(Model);
    var pct = ProductPricing.GetDiscountPercentDisplay(Model);
}
<div class="card product-card h-100 border-0 shadow-sm">
    <div class="product-card-img-wrap position-relative">
        @if (hasDisc)
        {
            <span class="badge bg-danger position-absolute top-0 end-0 m-2 shadow-sm">−@pct%</span>
        }
        <img src="@img" class="card-img-top" alt="@Model.Name" loading="lazy" />
        <div class="product-card-overlay">
            <a class="btn btn-light btn-sm" asp-controller="Products" asp-action="Details" asp-route-id="@Model.Id">Xem chi tiết</a>
        </div>
    </div>
    <div class="card-body d-flex flex-column">
        <p class="text-muted small mb-1">@Model.Category?.Name</p>
        <h3 class="card-title h6 mb-2">@Model.Name</h3>
        @if (hasDisc)
        {
            <p class="mb-0"><del class="text-muted small">@Model.Price.ToString("N0") đ</del></p>
            <p class="price-tag mb-3 mt-1">@effective.ToString("N0") <span class="currency">đ</span></p>
        }
        else
        {
            <p class="price-tag mb-3 mt-auto">@Model.Price.ToString("N0") <span class="currency">đ</span></p>
        }
        @if (auth && Model.Stock > 0)
        {
            <form asp-controller="Cart" asp-action="Add" method="post" class="d-grid mt-auto" data-loading>
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@Model.Id" />
                <input type="hidden" name="quantity" value="1" />
                <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                <button type="submit" class="btn btn-brand btn-sm">Thêm vào giỏ</button>
            </form>
        }
        else if (!auth)
        {
            <a class="btn btn-outline-secondary btn-sm mt-auto" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path">Đăng nhập để mua</a>
        }
        else
        {
            <span class="text-muted small mt-auto">Hết hàng</span>
        }
    </div>
</div>
